generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                    String   @id @default(cuid())
  email                 String
  firmName              String?
  googlePlaceId         String?
  normalizedDomain      String?
  website               String?
  phone                 String?
  practiceArea          String?
  secondaryPracticeArea String?
  city                  String?
  state                 String?
  country               String   @default("US")
  lat                   Float?
  lng                   Float?
  isNewFirm             Boolean  @default(false)
  intakeAnswers         Json?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  referrer              String?
  clickId               String?
  gclid                 String?
  territoryAvailable    Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  marketGapReports          MarketGapReport[]
  aiSearchReports           AiSearchReport[]
  growthPathSessions        GrowthPathSession[]
  competitorScanReports     CompetitorScanReport[]

  @@index([email])
  @@index([googlePlaceId])
  @@index([normalizedDomain])
  @@map("leads")
}

model MarketGapReport {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  accessToken     String   @unique @default(cuid())
  status          String   @default("pending")
  practiceArea    String
  city            String
  state           String
  country         String   @default("US")
  lat             Float?
  lng             Float?

  // Teaser data
  totalSearchVolume   Int?
  localSearchVolume   Int?
  mapPackCompetitors  Json?
  firmInMapPack       Boolean?
  firmRating          Float?
  firmReviewCount     Int?
  biggestGap          String?
  keywordData         Json?
  aiSearchData        Json?
  searchVolumeMethodology Json?
  serpScreenshots      Json?
  pageSpeedData       Json?

  // Full report data
  organicSerpData     Json?
  authorityData       Json?
  aiVisibilityData    Json?
  contentCoverage     Json?
  visibilityScore     Int?
  gapScore            Int?
  opportunityScore    Float?
  executiveSummary    String?
  biggestGaps         Json?
  fastestWins         Json?
  ninetyDayPriorities Json?
  recommendedService  String?
  intakeDragEstimate  Json?

  // Admin
  approvedAt      DateTime?
  approvedBy      String?
  teamNotes       String?
  emailSentAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitors     MarketGapCompetitor[]
  keywords        MarketGapKeyword[]
  events          MarketGapEvent[]

  @@index([leadId])
  @@index([accessToken])
  @@index([status])
  @@map("market_gap_reports")
}

model MarketGapCompetitor {
  id              String   @id @default(cuid())
  reportId        String
  report          MarketGapReport @relation(fields: [reportId], references: [id])
  name            String
  placeId         String?
  domain          String?
  rating          Float?
  reviewCount     Int?
  mapPackPosition Int?
  organicPosition Int?
  referringDomains Int?
  cid             String?
  checkUrl        String?

  createdAt       DateTime @default(now())

  @@index([reportId])
  @@map("market_gap_competitors")
}

model MarketGapKeyword {
  id              String   @id @default(cuid())
  reportId        String
  report          MarketGapReport @relation(fields: [reportId], references: [id])
  keyword         String
  searchVolume    Int?
  localSearchVolume Int?
  trend           Json?
  organicPosition Int?
  firmRanking     Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([reportId])
  @@map("market_gap_keywords")
}

model MarketGapEvent {
  id        String   @id @default(cuid())
  reportId  String
  report    MarketGapReport @relation(fields: [reportId], references: [id])
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([event])
  @@map("market_gap_events")
}

model AiSearchReport {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id])
  practiceArea String
  city         String
  state        String
  country      String   @default("US")
  firmDomain   String?
  results      Json?
  queriesRun   Int      @default(0)
  queriesFound Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
  @@map("ai_search_reports")
}

model FormSubmission {
  id        String   @id @default(cuid())
  type      String   // "contact", "growth-assessment", "market-report", "ghost-lead", "quote"
  name      String
  email     String
  phone     String?
  firmName  String?
  data      Json
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("form_submissions")
}

// ─── Growth Path ──────────────────────────────────────────────

model GrowthPathSession {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  accessToken     String   @unique @default(cuid())
  status          String   @default("intake") // intake|scanning|scoring|report_ready|reviewed
  flowType        String   // new_firm|existing_firm
  intakeAnswers   Json?
  practiceArea    String?
  city            String?
  state           String?
  country         String   @default("US")
  lat             Float?
  lng             Float?
  website         String?
  firmDomain      String?
  brandRoute      String   @default("jurispage") // jurispage|juris_digital
  overriddenPath  String?
  reviewedBy      String?
  reviewedAt      DateTime?
  teamNotes       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scans           GrowthPathScan[]
  score           GrowthPathScore?
  recommendation  GrowthPathRecommendation?
  events          GrowthPathEvent[]
  assets          GrowthPathAsset[]

  @@index([leadId])
  @@index([accessToken])
  @@index([status])
  @@map("growth_path_sessions")
}

model GrowthPathScan {
  id          String    @id @default(cuid())
  sessionId   String
  session     GrowthPathSession @relation(fields: [sessionId], references: [id])
  scanType    String    // keyword_volume|serp_analysis|serp_screenshot|maps_competition|website_screenshot|vision_analysis|pagespeed|competitor_density
  status      String    @default("pending") // pending|running|complete|failed
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sessionId])
  @@index([scanType])
  @@map("growth_path_scans")
}

model GrowthPathScore {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         GrowthPathSession @relation(fields: [sessionId], references: [id])
  urgency         Int      @default(0)
  foundation      Int      @default(0)
  visibilityGap   Int      @default(0)
  websiteClarity  Int      @default(0)
  leadQuality     Int      @default(0)
  legacyFit       Int      @default(0)
  committeeScore  Int      @default(0)
  rawInputs       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("growth_path_scores")
}

model GrowthPathRecommendation {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  session          GrowthPathSession @relation(fields: [sessionId], references: [id])
  primaryPath      String
  secondaryPath    String?
  notYetPath       String?
  brandRoute       String   @default("jurispage")
  explanationShort String?
  explanationLong  String?
  days1to30        Json?
  days31to60       Json?
  days61to90       Json?
  internalScores   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("growth_path_recommendations")
}

model GrowthPathEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   GrowthPathSession @relation(fields: [sessionId], references: [id])
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([event])
  @@map("growth_path_events")
}

model GrowthPathAsset {
  id        String   @id @default(cuid())
  sessionId String
  session   GrowthPathSession @relation(fields: [sessionId], references: [id])
  assetType String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("growth_path_assets")
}

model CompetitorScanReport {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  targetUrl       String
  targetDomain    String
  city            String
  practiceArea    String
  searchQuery     String
  localPackItems  Json?
  organicItems    Json?
  targetRank      Int?
  targetInLocalPack Boolean @default(false)
  rawResponse     Json?
  createdAt       DateTime @default(now())

  @@index([leadId])
  @@map("competitor_scan_reports")
}

model Territory {
  id            String   @id @default(cuid())
  practiceArea  String
  city          String
  state         String
  country       String   @default("US")
  claimedBy     String?
  claimedAt     DateTime?
  createdAt     DateTime @default(now())

  @@unique([practiceArea, city, state, country])
  @@map("territories")
}

model LaunchpadQuote {
  id            String   @id @default(cuid())
  name          String
  email         String
  attorneys     Int
  practiceArea  String
  citySize      String
  addonChatbot  Boolean  @default(false)
  addonLogo     Boolean  @default(false)
  monthlyTotal  Int?
  oneTimeTotal  Int      @default(0)
  isCustom      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("launchpad_quotes")
}
