generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                    String   @id @default(cuid())
  email                 String
  firmName              String?
  googlePlaceId         String?
  normalizedDomain      String?
  website               String?
  phone                 String?
  practiceArea          String?
  secondaryPracticeArea String?
  city                  String?
  state                 String?
  country               String   @default("US")
  lat                   Float?
  lng                   Float?
  isNewFirm             Boolean  @default(false)
  intakeAnswers         Json?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  referrer              String?
  clickId               String?
  gclid                 String?
  territoryAvailable    Boolean?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  marketGapReports MarketGapReport[]

  @@index([email])
  @@index([googlePlaceId])
  @@index([normalizedDomain])
  @@map("leads")
}

model MarketGapReport {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  accessToken     String   @unique @default(cuid())
  status          String   @default("pending")
  practiceArea    String
  city            String
  state           String
  country         String   @default("US")
  lat             Float?
  lng             Float?

  // Teaser data
  totalSearchVolume   Int?
  localSearchVolume   Int?
  mapPackCompetitors  Json?
  firmInMapPack       Boolean?
  firmRating          Float?
  firmReviewCount     Int?
  biggestGap          String?
  keywordData         Json?
  aiSearchData        Json?

  // Full report data
  organicSerpData     Json?
  authorityData       Json?
  aiVisibilityData    Json?
  contentCoverage     Json?
  visibilityScore     Int?
  gapScore            Int?
  opportunityScore    Float?
  executiveSummary    String?
  biggestGaps         Json?
  fastestWins         Json?
  ninetyDayPriorities Json?
  recommendedService  String?
  intakeDragEstimate  Json?

  // Admin
  approvedAt      DateTime?
  approvedBy      String?
  teamNotes       String?
  emailSentAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  competitors     MarketGapCompetitor[]
  keywords        MarketGapKeyword[]
  events          MarketGapEvent[]

  @@index([leadId])
  @@index([accessToken])
  @@index([status])
  @@map("market_gap_reports")
}

model MarketGapCompetitor {
  id              String   @id @default(cuid())
  reportId        String
  report          MarketGapReport @relation(fields: [reportId], references: [id])
  name            String
  placeId         String?
  domain          String?
  rating          Float?
  reviewCount     Int?
  mapPackPosition Int?
  organicPosition Int?
  referringDomains Int?
  cid             String?
  checkUrl        String?

  createdAt       DateTime @default(now())

  @@index([reportId])
  @@map("market_gap_competitors")
}

model MarketGapKeyword {
  id              String   @id @default(cuid())
  reportId        String
  report          MarketGapReport @relation(fields: [reportId], references: [id])
  keyword         String
  searchVolume    Int?
  localSearchVolume Int?
  trend           Json?
  organicPosition Int?
  firmRanking     Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([reportId])
  @@map("market_gap_keywords")
}

model MarketGapEvent {
  id        String   @id @default(cuid())
  reportId  String
  report    MarketGapReport @relation(fields: [reportId], references: [id])
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([event])
  @@map("market_gap_events")
}

model Territory {
  id            String   @id @default(cuid())
  practiceArea  String
  city          String
  state         String
  country       String   @default("US")
  claimedBy     String?
  claimedAt     DateTime?
  createdAt     DateTime @default(now())

  @@unique([practiceArea, city, state, country])
  @@map("territories")
}
